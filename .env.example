VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AI tutor. Set to "false" to hide the AI tutor UI entirely.
VITE_ENABLE_AI=true

# AI provider for the tutor:
#   "firebase" = Firebase AI Logic / Gemini (client-side, default)
#   "openai"   = OpenAI via the secure tutorChallenge Cloud Function (needs Blaze)
#   "worker"   = OpenAI via a free Cloudflare Worker proxy (no Blaze needed)
# NEVER put an OpenAI key in this file or any VITE_* var — it ships to the browser.
# The OpenAI key lives only in the server (Worker secret / Secret Manager).
VITE_AI_PROVIDER=firebase

# Only used when VITE_AI_PROVIDER=worker. Public URL of your Cloudflare Worker,
# e.g. https://pathwise-tutor.<your-subdomain>.workers.dev  (see worker/README.md)
VITE_AI_PROXY_URL=
